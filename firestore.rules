rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          'cebrailkara@gmail.com',
          'info@beyogluteknoloji.com',
          'cebokar@gmail.com'
        ];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isShortText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isValidContactMessage() {
      let data = request.resource.data;

      return data.keys().hasAll([
          'name',
          'email',
          'phone',
          'message',
          'createdAt'
        ])
        && data.keys().hasOnly([
          'name',
          'email',
          'phone',
          'message',
          'source',
          'page',
          'status',
          'userAgent',
          'createdAt'
        ])
        && isShortText(data.name, 2, 80)
        && isShortText(data.email, 5, 120)
        && isShortText(data.phone, 7, 32)
        && isShortText(data.message, 10, 1000)
        && (!('source' in data) || data.source == 'landing-contact')
        && (!('status' in data) || data.status == 'new')
        && (!('page' in data) || isShortText(data.page, 1, 120))
        && (!('userAgent' in data) || isShortText(data.userAgent, 1, 240));
    }

    match /messages/{messageId} {
      allow create: if isValidContactMessage();
      allow read, update, delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /{document=**} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
