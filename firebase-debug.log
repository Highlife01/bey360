[debug] [2026-05-13T15:44:02.183Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/advera-c8dd0/rulesets {"name":"projects/advera-c8dd0/rulesets/38b587f7-66e1-4f99-93c4-27aa236f30cd","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isSuperAdmin() {\n      return isSignedIn()\n        && request.auth.token.email in [\n          'cebrailkara@gmail.com',\n          'info@beyogluteknoloji.com',\n          'cebokar@gmail.com'\n        ];\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n\n    function isShortText(value, min, max) {\n      return value is string && value.size() >= min && value.size() <= max;\n    }\n\n    function isValidContactMessage() {\n      let data = request.resource.data;\n\n      return data.keys().hasOnly([\n          'name',\n          'email',\n          'phone',\n          'message',\n          'source',\n          'page',\n          'status',\n          'userAgent',\n          'createdAt'\n        ])\n        && isShortText(data.name, 2, 80)\n        && isShortText(data.email, 5, 120)\n        && isShortText(data.phone, 7, 32)\n        && isShortText(data.message, 10, 1000)\n        && data.source == 'landing-contact'\n        && data.status == 'new'\n        && isShortText(data.page, 1, 120)\n        && isShortText(data.userAgent, 1, 240)\n        && data.createdAt == request.time;\n    }\n\n    match /messages/{messageId} {\n      allow create: if isValidContactMessage();\n      allow read, update, delete: if isSuperAdmin();\n    }\n\n    match /users/{userId} {\n      allow read, create, update: if isOwner(userId) || isSuperAdmin();\n      allow delete: if isSuperAdmin();\n\n      match /{document=**} {\n        allow read, write: if isOwner(userId) || isSuperAdmin();\n      }\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-13T15:43:59.544031Z","metadata":{"services":["cloud.firestore"]}}
